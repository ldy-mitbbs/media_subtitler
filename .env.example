# --- Media ---
MEDIA_DIR=media

# --- Whisper ---
# Backend: faster-whisper | remote-faster-whisper | whispercpp | openai | auto
WHISPER_BACKEND=auto
WHISPER_MODEL=large-v3
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto
WHISPER_CPP_COMMAND=whisper-cli
WHISPER_CPP_MODEL_PATH=
WHISPER_CPP_THREADS=0

# Optional remote GPU host. If set to http://<gpu-pc-ip>, the app derives:
#   REMOTE_WHISPER_BASE_URL=http://<gpu-pc-ip>:5051
#   OLLAMA_BASE_URL=http://<gpu-pc-ip>:11434
GPU_BASE_URL=
REMOTE_WHISPER_BASE_URL=

# --- Translation ---
# Backend: ollama | openrouter | deepseek
TRANSLATION_BACKEND=deepseek
TRANSLATION_MODEL=deepseek-v4-flash
TRANSLATION_CHUNK_SIZE=20
TRANSLATION_TIMEOUT=120

OLLAMA_BASE_URL=

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_REFERER=
OPENROUTER_APP_TITLE=drama_subtitler

DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=

# --- Languages ---
# Default target language for new jobs (per-job override available in the UI).
TARGET_LANGUAGE=zh
